# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/ai_bot_db
# Or for SQLite (development): sqlite:///app.db

# Server Configuration
BASE_URL=https://yourdomain.com
WEBHOOK_SECRET_PATH=/webhook/secret/path/here

# Timezone Configuration
TIMEZONE=Europe/Moscow

# Premium Subscription Settings
PREMIUM_PRICE_MIN=2000

# Market Data Polling
PRICE_POLL_INTERVAL_SEC=300

# Payment Verification
VERIFY_TOKEN=your_secure_payment_verification_code

# MOEX Market Boards
MARKET_BOARD_SHARES=TQBR
MARKET_BOARD_ETF=TQTF
MARKET_BOARD_BONDS=TQOB

# Logging Configuration (optional)
LOG_LEVEL=INFO
LOG_FILE=/app/logs/bot.log

# Security (optional)
SECRET_KEY=your_secret_key_for_sessions
